FROM python:3.14-slim

WORKDIR /app

# Install dependencies
COPY requirements.txt .
RUN pip install -r requirements.txt

# Copy your app code and index.html
COPY app.py .
COPY index.html .

# Expose the port
EXPOSE 8000

# Ensure the database has a place to live
RUN touch memory.db

# We use an environment variable for the model name
ENTRYPOINT ["python", "app.py"]
CMD ["--model", "gemma4:e4b"]